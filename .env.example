# Postgres connection string. For local dev, the fastest free option is
# Neon (https://neon.tech) — create a project, copy the pooled connection
# string here. For Vercel deploys, set this in the Vercel project settings;
# Vercel Postgres / Neon integrations populate it automatically.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Optional. When set, the value-index refresh routes require
# `Authorization: Bearer <CRON_SECRET>` — use this to gate the Vercel cron
# endpoints from random traffic.
# CRON_SECRET=

# Optional. eBay Browse API credentials for per-card market signal.
# Register a free production app at https://developer.ebay.com/my/keys
# EBAY_APP_ID=
# EBAY_CERT_ID=
# EBAY_ENV=production
