# Postgres connection string. For local dev, the fastest free option is
# Neon (https://neon.tech) — create a project, copy the pooled connection
# string here. For Vercel deploys, set this in the Vercel project settings;
# Vercel Postgres / Neon integrations populate it automatically.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Optional. When set, Vercel cron endpoints require
# `Authorization: Bearer <CRON_SECRET>` — gates scheduled refreshes
# (PriceCharting, eBay value-index, etc.) from random traffic.
# CRON_SECRET=

# Optional. Set in Preview/Development only — gates a manual one-shot
# trigger of /api/cron/refresh-pricecharting via `?secret=<ADMIN_SECRET>`.
# Used to bootstrap a brand-new tracked set without waiting for the next
# 9 AM cron tick. Production should NOT have this set; cron auth via
# CRON_SECRET only.
# ADMIN_SECRET=

# Optional. eBay Browse API credentials for per-card market signal.
# Register a free production app at https://developer.ebay.com/my/keys
# EBAY_APP_ID=
# EBAY_CERT_ID=
# EBAY_ENV=production
