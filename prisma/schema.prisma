generator client {
  provider = "prisma-client-js"
}

// We use Postgres in both dev and prod. Local dev can point at a free
// Neon project (https://neon.tech) — takes ~30 seconds to create and the
// connection string drops straight into .env. Prisma can't take provider
// from env() so we commit the literal here; if you want to fall back to
// SQLite locally, swap the provider value and DATABASE_URL together.
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id                  String      @id @default(cuid())
  name                String
  sport               String
  manufacturer        String?
  releaseDate         DateTime?
  releaseStatus       String      @default("announced") // announced | released | delayed | cancelled
  source              String      @default("manual")    // manual | api:<provider>
  externalId          String?
  // Total per-buyer slot price for one full break of this product (cents).
  // The only variable in retail pricing — everything else is algorithm.
  boxPriceCents       Int?
  // When per-card market values were last refreshed product-wide.
  lastMarketRefreshAt DateTime?
  cards               Card[]
  teamPrices          TeamPrice[]
  breaks              UserBreak[]
  mixers              MixerProduct[]
  favorites           UserFavoriteProduct[]
  formats             ProductFormat[]
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @default(now()) @updatedAt

  @@unique([source, externalId], name: "source_externalId")
}

model Card {
  id               String     @id @default(cuid())
  productId        String
  team             String
  playerName       String
  cardNumber       String
  variation        String?
  // Per-card market signal — populated by the eBay fetcher.
  // Median asking price across recent active listings, in cents. Used in the
  // composite scoring blend in src/lib/scoring.ts.
  marketValueCents Int?
  marketSampleSize Int?
  marketObservedAt DateTime?
  product          Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  userCards        UserCard[]

  @@index([productId, team])
}

model TeamPrice {
  id             String    @id @default(cuid())
  productId      String
  team           String
  // Breaker's contract cost for this team slot (cents). The one human input
  // on this row — everything else is algorithmic.
  wholesaleCents Int?
  // Legacy team-level eBay aggregate from Phase-2 v1 (per-team listing index).
  // Kept for backwards compat; the live signal now lives on Card.marketValueCents
  // and is rolled up at query time. Safe to remove later.
  valueIndexCents Int?
  lastIndexedAt   DateTime?
  indexSampleSize Int?
  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, team])
}

model UserBreak {
  id         String   @id @default(cuid())
  userId     String   @default("local")
  productId  String
  teamsOwned String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([userId, productId])
}

// A multi-product break session — what breakers run as "mixers"
// (e.g. "KKSPORTSCARDS Topps Chrome Black / Bowman Draft / Definitive").
//
// Pricing: one boxPriceCents covers the whole mixer (per-buyer slot price).
// Per-team retail = (team's combined Break Score across all products
// in the mixer / total combined Break Score) × boxPriceCents.
//
// breakerHandle is optional metadata so mixers can be attributed to a
// specific breaker (KKSPORTSCARDS) for sharing.
model Mixer {
  id            String          @id @default(cuid())
  userId        String          @default("local")
  name          String
  breakerHandle String?
  boxPriceCents Int?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @default(now()) @updatedAt
  products      MixerProduct[]
  picks         MixerPick[]

  @@index([userId])
}

model MixerProduct {
  mixerId   String
  productId String
  mixer     Mixer   @relation(fields: [mixerId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([mixerId, productId])
  @@index([productId])
}

// The buyer's selected teams (canonical names) for a mixer break. Mirrors
// UserBreak.teamsOwned but scoped to a mixer instead of a single product.
model MixerPick {
  id         String   @id @default(cuid())
  mixerId    String
  userId     String   @default("local")
  teamsOwned String
  mixer      Mixer    @relation(fields: [mixerId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([mixerId, userId])
}

model UserCard {
  id     String @id @default(cuid())
  userId String @default("local")
  cardId String
  status String
  card   Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([userId, cardId])
}

// Box formats for a product — Hobby, Jumbo, Mega Box, Super Jumbo,
// Breaker Delight, Retail, etc. A single Product (e.g. "2025 Bowman
// Draft Baseball") has multiple formats with different box prices,
// pack configurations, auto counts, and (eventually) different
// pull-eligible card subsets.
//
// Phase 1 (now): metadata only — so users can compare prices + odds
// and read exclusivity notes ("Mega Box: 2 exclusive Chrome packs").
// Card-level format restrictions come in Phase 2.
model ProductFormat {
  id              String   @id @default(cuid())
  productId       String
  // Display name. Free-text rather than enum so unusual formats
  // ("Hanger Box", "Vending Box", "FOTL", "Choice Box") fit without
  // a schema change.
  name            String
  // Per-buyer slot price for one full box of this format (cents).
  boxPriceCents   Int?
  packsPerBox     Int?
  cardsPerPack    Int?
  // Float because expected autos can be fractional ("avg 1.5 per
  // box for some retail formats").
  autosPerBox     Float?
  // Format-specific exclusives, odds caveats, or breaker notes.
  // Free-text — surfaced as a small italics line on the format card.
  notes           String?
  // Sort order on the product page. Lower = leftmost. Tie-break by
  // boxPriceCents ascending, then by createdAt.
  position        Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, name])
  @@index([productId])
}

// Per-user product favorites — pinned products that show up under the
// /favorites page and the Favorites nav link. Mirrors the UserCard /
// UserBreak pattern: userId defaults to "local" until real auth lands,
// at which point we drop the default and the same data flows through.
model UserFavoriteProduct {
  id        String   @id @default(cuid())
  userId    String   @default("local")
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}
